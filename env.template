# ============================================
# SocialHub Global V5 - Configuration
# ============================================
# Copier ce fichier en .env et remplir avec vos vraies valeurs

# Node Environment
NODE_ENV=production

# Application
PORT=3000
APP_URL=https://socialhub.votredomaine.com

# ============================================
# Database Configuration
# ============================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/socialhub

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Upload local (optionnel)
LOCAL_UPLOAD_MAX_MB=200

# ============================================
# Cloudinary (Upload de médias)
# ============================================
# Obtenir sur: https://cloudinary.com/console

CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret
CLOUDINARY_UPLOAD_PRESET=votre_preset

# ============================================
# Meta / Facebook / Instagram
# ============================================
# Obtenir sur: https://developers.facebook.com/apps/

META_APP_ID=votre_app_id
META_APP_SECRET=votre_app_secret
META_REDIRECT_URI=https://socialhub.votredomaine.com/api/auth/meta/callback

# ============================================
# TikTok
# ============================================
# Obtenir sur: https://developers.tiktok.com/apps/

TIKTOK_CLIENT_KEY=votre_client_key
TIKTOK_CLIENT_SECRET=votre_client_secret
TIKTOK_REDIRECT_URI=https://socialhub.votredomaine.com/api/auth/tiktok/callback

# ============================================
# Email (SMTP) - Optionnel
# ============================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_app
SMTP_FROM=votre_email@gmail.com

# ============================================
# Social Media Data Collection APIs
# ============================================
# Pour collecter les vraies données des influenceurs

# YouTube Data API v3 (Gratuit - https://console.cloud.google.com/)
YOUTUBE_API_KEY=votre_youtube_api_key

# Facebook Graph API (https://developers.facebook.com/)
FACEBOOK_ACCESS_TOKEN=votre_facebook_access_token

# RapidAPI (Optionnel - pour Instagram, TikTok, etc.)
# Inscrivez-vous sur https://rapidapi.com/
RAPIDAPI_KEY=votre_rapidapi_key

# ============================================
# Security (Optionnel)
# ============================================

# JWT Secret (générer avec: openssl rand -base64 32)
JWT_SECRET=generer_une_cle_secrete_aleatoire

# Session Secret (générer avec: openssl rand -base64 32)
SESSION_SECRET=generer_une_autre_cle_secrete

